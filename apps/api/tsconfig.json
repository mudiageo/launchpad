{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "nodenext",
                            "moduleResolution":  "nodenext",
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "outDir":  "./dist",
                            "rootDir":  "./src",
                            "declaration":  true,
                            "resolveJsonModule":  true,
                            "allowImportingTsExtensions":  true,
                            "noEmit":  true
                        },
    "include":  [
                    "src"
                ],
    "exclude":  [
                    "node_modules",
                    "dist"
                ]
}
